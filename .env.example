NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_GRAPHQL_API_URL=http://localhost:8000/graphql

PLANAHEAD_PORT=8000
PLANAHEAD_ALLOWED_ORIGIN=http://localhost:3000
PLANAHEAD_DB_DRIVER=mysql
PLANAHEAD_DB_DSN=root@tcp(127.0.0.1:3306)/degree_tracker?parseTime=true
PLANAHEAD_MOCK_USER_ID=local-demo-user

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_DATABASE=degree_tracker

AUTH0_DOMAIN=your-auth0-domain
AUTH0_CLIENT_ID=your-auth0-client-id
AUTH0_CLIENT_SECRET=your-auth0-client-secret
AUTH0_AUDIENCE=your-auth0-audience
AUTH0_ISSUER_BASE_URL=https://your-auth0-domain/
AUTH0_SECRET=replace_me_later
